# VCS
.git/
.gitignore

# Environment files
.env
.env.*
!.env.example

# Python caches and virtualenvs
**/__pycache__/
**/*.py[cod]
**/.venv/
**/venv/

# Test and lint caches
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.coverage
**/htmlcov/

# Build artifacts
**/*.egg-info/
**/build/
**/dist/

# Editor artifacts
**/.idea/
**/.vscode/
**/.DS_Store

