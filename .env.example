ENVIRONMENT=development
LOG_LEVEL=INFO
API_NAME=AI Document Q&A Assistant API
API_VERSION=0.1.0
API_PREFIX=/api/v1
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_DB=rag_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rag_app
DATABASE_ECHO=false

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//
REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=replace-with-real-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-5.4-mini

AUTH_PROVIDER=clerk
CLERK_JWKS_URL=https://example.com/.well-known/jwks.json
SUPABASE_JWKS_URL=https://example.com/auth/v1/keys

SENTRY_DSN=
MAX_UPLOAD_SIZE_MB=25
RETRIEVAL_INITIAL_TOP_K=20
RETRIEVAL_FINAL_TOP_K=5
CHUNK_SIZE_TOKENS=700
CHUNK_OVERLAP_TOKENS=120
REQUEST_TIMEOUT_SECONDS=30

FEATURE_ENABLE_EMBEDDINGS=true
FEATURE_ENABLE_LLM=true
FEATURE_ENABLE_EVALUATIONS=true
FEATURE_ENABLE_PIPELINE_EXPLORER=true
FEATURE_EXPOSE_CONFIG_SNAPSHOT=true
