ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=auto
API_NAME=AI Document Q&A Assistant API
API_VERSION=0.1.0
API_PREFIX=/api/v1
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_DB=rag_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Local-host defaults (API/worker running on host machine).
# docker-compose overrides these for containerized API/worker.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_app
DATABASE_ECHO=false

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=documents
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT_SECONDS=2
QDRANT_BOOTSTRAP_COLLECTION=true

MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=documents
MINIO_BOOTSTRAP_BUCKET=true

RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin123
RABBITMQ_URL=amqp://admin:admin123@localhost:5672//
RABBITMQ_CONNECT_TIMEOUT_SECONDS=2
CELERY_RESULT_BACKEND_ENABLED=true
CELERY_TASK_DEFAULT_QUEUE=default
CELERY_QUEUE_DOCUMENTS_PROCESSING=documents.processing
CELERY_QUEUE_DOCUMENTS_DELETION=documents.deletion
CELERY_QUEUE_DOCUMENTS_REINDEX=documents.reindex
CELERY_QUEUE_EVALUATIONS=evaluations
CELERY_TASK_MAX_RETRIES=5
CELERY_RETRY_BACKOFF_SECONDS=2
CELERY_RETRY_BACKOFF_MAX_SECONDS=60
CELERY_RETRY_JITTER=true
CELERY_WORKER_PREFETCH_MULTIPLIER=1
REDIS_URL=redis://localhost:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DISABLE_IN_DEVELOPMENT=true
RATE_LIMIT_DISABLE_IN_TEST=true
RATE_LIMIT_REDIS_FAILURE_MODE=open
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_UPLOAD_REQUESTS=20
RATE_LIMIT_CHAT_REQUESTS=30
RATE_LIMIT_EVALUATION_REQUESTS=10
RATE_LIMIT_DELETE_REQUESTS=20
RATE_LIMIT_ADMIN_REQUESTS=15
EVALUATION_PREVENT_DUPLICATE_ACTIVE_RUNS=true

DEPENDENCY_CONNECT_TIMEOUT_SECONDS=1
DEPENDENCY_READ_TIMEOUT_SECONDS=1
DEPENDENCY_MAX_RETRIES=0

OPENAI_API_KEY=replace-with-real-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-5.4-mini
LLM_RETRY_MAX_ATTEMPTS=2
LLM_RETRY_BASE_SECONDS=0.4
LLM_RETRY_MAX_SECONDS=3
OPENAI_LLM_INPUT_COST_PER_MILLION_TOKENS_USD=0.0
OPENAI_LLM_OUTPUT_COST_PER_MILLION_TOKENS_USD=0.0

AUTH_PROVIDER=app
APP_AUTH_SECRET=dev-insecure-change-me
APP_AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
APP_AUTH_ISSUER=rudix-app
APP_AUTH_AUDIENCE=rudix-api
AUTH_JWKS_CACHE_TTL_SECONDS=300
# Future provider-specific settings:
CLERK_JWKS_URL=https://example.com/.well-known/jwks.json
CLERK_JWT_ISSUER=https://clerk.example.com
CLERK_JWT_AUDIENCE=rudix-api
SUPABASE_JWKS_URL=https://example.com/auth/v1/keys
SUPABASE_JWT_ISSUER=https://project-ref.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_ERROR_SAMPLE_RATE=
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_PROFILES_SAMPLE_RATE=
SENTRY_TEST_EVENT_ENABLED=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ERROR_SAMPLE_RATE=1
NEXT_PUBLIC_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PUBLIC_APP_URL=
NEXT_PUBLIC_PUBLIC_PRODUCT_URL=
NEXT_PUBLIC_PUBLIC_SOLUTIONS_URL=
NEXT_PUBLIC_PUBLIC_SECURITY_URL=
NEXT_PUBLIC_PUBLIC_PRICING_URL=
NEXT_PUBLIC_PUBLIC_DOCS_URL=
NEXT_PUBLIC_PUBLIC_TRIAL_URL=
NEXT_PUBLIC_PUBLIC_DEMO_URL=
NEXT_PUBLIC_PUBLIC_CONTACT_URL=
NEXT_PUBLIC_PUBLIC_SECURITY_CONTACT_URL=
NEXT_PUBLIC_PUBLIC_STATUS_URL=
NEXT_PUBLIC_PUBLIC_LOGIN_URL=
MAX_UPLOAD_SIZE_MB=25
RETRIEVAL_INITIAL_TOP_K=20
RETRIEVAL_FINAL_TOP_K=5
RERANK_MMR_LAMBDA=0.7
RERANK_MMR_CANDIDATE_COUNT=20
RERANK_MMR_DUPLICATE_SIMILARITY_THRESHOLD=0.92
CONFIDENCE_WEIGHT_TOP_SIMILARITY=0.35
CONFIDENCE_WEIGHT_AVERAGE_SIMILARITY=0.20
CONFIDENCE_WEIGHT_RERANK_SCORE=0.20
CONFIDENCE_WEIGHT_CITATION_SUPPORT=0.15
CONFIDENCE_WEIGHT_AGREEMENT=0.10
CONFIDENCE_MEDIUM_THRESHOLD=0.50
CONFIDENCE_HIGH_THRESHOLD=0.80
CONFIDENCE_NOT_FOUND_THRESHOLD=0.20
CONFIDENCE_NOT_FOUND_PENALTY_MULTIPLIER=0.35
CONFIDENCE_CITATION_COVERAGE_TARGET=2
CHUNK_SIZE_TOKENS=700
CHUNK_OVERLAP_TOKENS=120
DOCUMENT_INDEX_VERSION=v1
EMBEDDING_BATCH_MAX_ITEMS=96
EMBEDDING_BATCH_MAX_TOKENS=100000
EMBEDDING_RETRY_MAX_ATTEMPTS=3
EMBEDDING_RETRY_BASE_SECONDS=0.5
EMBEDDING_RETRY_MAX_SECONDS=8
OPENAI_EMBEDDING_COST_PER_MILLION_TOKENS_USD=0.02
REQUEST_TIMEOUT_SECONDS=30
AGENT_MAX_STEPS=12
AGENT_MAX_PARALLEL_TOOL_CALLS=4
AGENT_TOOL_MAX_CALLS_PER_RUN=30
AGENT_TOOL_TIMEOUT_MS=8000
AGENT_TOOL_MAX_INPUT_BYTES=32768
AGENT_TOOL_MAX_OUTPUT_BYTES=65536
AGENT_TOOL_MAX_RETRY_ATTEMPTS=1
AGENT_PROMPT_INJECTION_GUARD_ENABLED=true
AGENT_DOCUMENT_INSTRUCTION_GUARD_ENABLED=true

FEATURE_ENABLE_EMBEDDINGS=true
FEATURE_ENABLE_LLM=true
FEATURE_ENABLE_EVALUATIONS=true
FEATURE_ENABLE_PIPELINE_EXPLORER=true
FEATURE_ENABLE_AGENTS=false
FEATURE_ENABLE_MCP=false
FEATURE_ENABLE_EXTERNAL_MCP_CONNECTORS=false
FEATURE_EXPOSE_CONFIG_SNAPSHOT=true
MCP_SERVER_NAME=Rudix MCP Server
MCP_TRANSPORT=streamable_http
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8010
MCP_HTTP_PATH=/mcp
MCP_REQUIRE_BEARER_AUTH=true
# Required only when MCP_TRANSPORT=stdio (development/test only):
MCP_DEV_PRINCIPAL_USER_ID=
MCP_DEV_PRINCIPAL_ORGANIZATION_ID=
MCP_DEV_PRINCIPAL_ROLES=
MCP_CAPABILITIES_OWNER=documents.read,documents.chunks.read,documents.summary.read,documents.compare.read,chat.answer,pipeline.read
MCP_CAPABILITIES_ADMIN=documents.read,documents.chunks.read,documents.summary.read,documents.compare.read,chat.answer,pipeline.read
MCP_CAPABILITIES_MEMBER=documents.read,documents.chunks.read,documents.summary.read,documents.compare.read,chat.answer,pipeline.read
MCP_CAPABILITIES_VIEWER=documents.read,documents.chunks.read,documents.summary.read,documents.compare.read,pipeline.read
MCP_RATE_LIMIT_ENABLED=true
MCP_RATE_LIMIT_WINDOW_SECONDS=60
MCP_RATE_LIMIT_REQUESTS=30
# JSON array of external MCP server definitions used by agent runtime.
# Example:
# MCP_EXTERNAL_SERVERS=[{"server_id":"acme_tools","enabled":true,"transport":"streamable_http","base_url":"https://mcp.example.com/mcp","auth_type":"bearer","auth_token":"replace-me","allow_tools":["lookup_customer"],"read_only_tools":["lookup_customer"],"required_roles":["owner","admin"]}]
MCP_EXTERNAL_SERVERS=[]
