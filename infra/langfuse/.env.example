# Copy this file to .env and fill in the required values before starting.
# Generate secrets with: openssl rand -hex 32

# Required
LANGFUSE_NEXTAUTH_SECRET=replace-with-32-char-random-string
LANGFUSE_SALT=replace-with-32-char-random-string

# Optional — defaults shown
LANGFUSE_POSTGRES_PASSWORD=langfuse
LANGFUSE_PORT=3030
LANGFUSE_NEXTAUTH_URL=http://localhost:3030
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false
